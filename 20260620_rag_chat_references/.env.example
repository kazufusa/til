# ============================================================
# RAG Chat with References — environment variables
# Copy to .env and fill in. (.env is gitignored)
# ============================================================

# --- PostgreSQL (docker compose で起動する DB) ---
# compose 側はこの3つを使う
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
# アプリ/取込スクリプトが使う接続文字列(ホストから docker の 5432 へ)
DATABASE_URL=postgres://rag:rag@localhost:5432/rag

# --- Google Vertex AI ---
GOOGLE_VERTEX_PROJECT=
GOOGLE_VERTEX_LOCATION=global

# --- モデル設定 ---
# チャット/検索エージェント用モデル(gemini 3.1 flash lite を使う想定。正式な model id を記入)
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
# 埋め込みモデル(3072次元)
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
# 埋め込み次元(pgvector の halfvec 次元と一致させること)
EMBEDDING_DIM=3072
