# === Gemini (Vertex AI) ===
# 認証は ADC を使う (API キー不要)。ローカルでは:
#   gcloud auth application-default login
# 送信先 GCP プロジェクトとリージョン
GOOGLE_VERTEX_PROJECT=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=us-central1
# 使用モデル (任意, 既定: gemini-2.5-flash)
GEMINI_MODEL=gemini-2.5-flash

# === OpenTelemetry エクスポート先 ===
# console: ローカル確認用に標準出力へ (既定)
# gcp:     Cloud Trace / Cloud Monitoring へ送信
OTEL_TARGET=console

# === Google Cloud (OTEL_TARGET=gcp のとき必要) ===
# trace/metric の送信先プロジェクト。未指定なら ADC のプロジェクトを使う。
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
