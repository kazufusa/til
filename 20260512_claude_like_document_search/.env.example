# Vertex AI (ADC で認証)
GOOGLE_VERTEX_PROJECT=your-gcp-project-id
GOOGLE_VERTEX_LOCATION=global

# Gemini Developer API (vertex の代わりに API key で使う場合)
# GOOGLE_GENERATIVE_AI_API_KEY=your-api-key

# Ollama (ローカル LLM)
# OLLAMA_BASE_URL=http://localhost:11434/api

# PostgreSQL (compose.yaml の値に合わせる)
# 例: postgres://USER:PASSWORD@HOST:PORT/DB
DATABASE_URL=

# 任意: 検索エージェントの内部ログ (デフォルト ON。OFF にしたいときだけ 0)
# CDCS_VERBOSE=0
